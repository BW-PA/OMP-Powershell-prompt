{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#56b6f7",
          "style": "plain",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "background": "#1e3a5c",
          "foreground": "#56b6f7",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "folder_separator_icon": "\\",
            "home_icon": "",
            "style": "full"
          },
          "style": "diamond",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#6CA35E",
          "foreground": "#ffffff",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "fetch_version": true
          },
          "style": "diamond",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "type": "node"
        },
        {
          "background": "#8ED1F7",
          "foreground": "#111111",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "fetch_version": true
          },
          "style": "diamond",
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "go"
        },
        {
          "background": "#4063D8",
          "foreground": "#111111",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "fetch_version": true
          },
          "style": "diamond",
          "template": " \ue624 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "julia"
        },
        {
          "background": "#FFDE57",
          "foreground": "#111111",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "style": "diamond",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "background": "#AE1401",
          "foreground": "#ffffff",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          },
          "style": "diamond",
          "template": " \ue791 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "ruby"
        },
        {
          "background": "#FEAC19",
          "foreground": "#ffffff",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "display_mode": "files",
            "fetch_version": false
          },
          "style": "diamond",
          "template": " \uf0e7{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "azfunc"
        },
        {
          "background_templates": [
            "{{if contains \"default\" .Profile}}#FFA400{{end}}",
            "{{if contains \"jan\" .Profile}}#f1184c{{end}}"
          ],
          "foreground": "#ffffff",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "display_default": false
          },
          "style": "diamond",
          "template": " \ue7ad {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
          "type": "aws"
        },
        {
          "background": "#ffff66",
          "foreground": "#111111",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "style": "diamond",
          "template": " \uf132 ",
          "type": "root"
        },
        {
          "background": "#83769c",
          "foreground": "#ffffff",
          "properties": {
            "always_enabled": false
          },
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "style": "diamond",
          "template": " \uf252 {{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "type": "exit",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#e91e63",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": " \u2717 {{ .Code }} - {{ .Meaning }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "type": "prompt",
      "segments": [
        {
          "type": "copilot",
          "style": "plain",
          "template": " <#d946ef>\uec1e</> {{ $t := 1000 }}{{ $f := int (min 10 (div (mul (int .Premium.Used) 10) $t)) }}{{ $e := int (sub 10 $f) }}<#4493f8>{{ repeat $f \"\u2022\" }}</><#555555>{{ repeat $e \"\u00b7\" }}</> {{ .Premium.Used }}/{{ $t }}",
          "foreground": "#4493f8",
          "cache": {
            "duration": "5m",
            "strategy": "session"
          },
          "options": {
            "http_timeout": 1000
          }
        }
      ]
    },
    {
      "type": "newline"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#56b6f7",
          "style": "plain",
          "template": "\u2502 ",
          "type": "text"
        },
        {
          "background": "#fffb38",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff4500{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FF{{ end }}"
          ],
          "foreground": "#193549",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "diamond",
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#56b6f7",
          "style": "plain",
          "template": "\n\u2570\u2500 ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "final_space": true,
  "version": 3
}